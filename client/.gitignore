# ==============================================================================
# 🚀 Elevate Humanity - Professional .gitignore
# ==============================================================================

# 1. SECURITY & ENVIRONMENT VARIABLES (CRITICAL)
# Never commit secrets, API keys, or database passwords!
.env
.env.*
!.env.example # It is okay to commit an example template without real passwords

# 2. DEPENDENCIES
node_modules/
.pnp
.pnp.js

# 3. BUILD OUTPUTS & CACHES
dist/
dist-ssr/
build/
out/
.cache/
.parcel-cache/
.eslintcache
.vite/

# 4. LOGS & DEBUGGING
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 5. TESTING & COVERAGE
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# 6. OS & SYSTEM FILES
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# 7. IDEs & EDITORS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.project
.classpath
.c9/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak